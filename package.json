{
  "name": "bedrockc",
  "version": "0.1.0",
  "description": "A production-oriented compiler and CLI for Minecraft Bedrock add-on projects.",
  "type": "module",
  "dependencies": {
    "ajv": "^8.17.1",
    "busboy": "^1.6.0",
    "jszip": "^3.10.1",
    "unzipper": "^0.12.3"
  },
  "bin": {
    "bedrockc": "./src/cli/index.js"
  },
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "node ./scripts/prepare-public.js",
    "compile": "node ./src/cli/index.js compile",
    "validate": "node ./src/cli/index.js validate",
    "watch": "node ./src/cli/index.js watch",
    "compiler:build": "node ./src/cli/index.js build",
    "compiler:compile": "node ./src/cli/index.js compile",
    "compiler:validate": "node ./src/cli/index.js validate",
    "compiler:watch": "node ./src/cli/index.js watch",
    "test": "node --test ./test/*.test.js"
  }
}
